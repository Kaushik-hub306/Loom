# GitHub token for API access (required)
GITHUB_TOKEN=ghp_xxx

# Webhook secret for verifying GitHub webhook signatures
LOOM_WEBHOOK_SECRET=your-secret-here

# LLM API key for convention extraction (at least one required)
ANTHROPIC_API_KEY=sk-ant-xxx
# or
OPENAI_API_KEY=sk-xxx

# Port for the server
PORT=8000

# ── OAuth 2.1 configuration (for loom-server) ──────────────────────
# GitHub OAuth App credentials
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Secret key for signing JWTs (use a long random string)
JWT_SECRET=your-jwt-secret-change-me

# Base URL for OAuth redirect callbacks
LOOM_BASE_URL=http://localhost:8000

# Database URL for the SQLite backend (optional; defaults to JSON file)
# DATABASE_URL=sqlite:///path/to/loom.db
