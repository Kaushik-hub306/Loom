# ── Storage ───────────────────────────────────────────────────────────
# Project root directory (optional — defaults to $PWD). .loom/ is created here.
LOOM_PROJECT_ROOT=/path/to/your/project

# Storage backend: "json" (default, local files) or "postgres" (team cloud)
# LOOM_STORAGE_BACKEND=json
# LOOM_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── LLM extraction (optional — keyword fallback is free) ─────────────
# Set ONE of these keys; the provider is auto-detected.
# ANTHROPIC_API_KEY=sk-ant-xxx
# LOOM_DEEPSEEK_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx

# Force a specific provider or model (optional)
# LOOM_LLM_PROVIDER=anthropic        # anthropic | deepseek | gemini
# LOOM_LLM_MODEL=claude-sonnet-5

# ── Privacy & access control ──────────────────────────────────────────
# Set to 1 to block all memory writes (read tools keep working)
# LOOM_PRIVATE_MODE=1

# Identity used for RBAC clearance checks on read paths
# LOOM_AGENT_ID=agent
# LOOM_AGENT_ROLE=member
# LOOM_AGENT_TEAMS=platform,infra

# ── Proxy mode ─────────────────────────────────────────────────────────
# JSON map of MCP servers Loom should spawn and forward to (proxy mode)
# LOOM_PROXY_TARGETS={"github": {"command": "npx", "args": ["-y", "@modelcontextprotocol/server-github"], "env": {}}}
