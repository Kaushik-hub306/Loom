# LLM API key for smarter convention extraction (optional — keyword fallback is free)
ANTHROPIC_API_KEY=sk-ant-xxx

# Project root directory (optional — defaults to $PWD)
LOOM_PROJECT_ROOT=/path/to/your/project

# Privacy mode — set to 1 to block writes and sanitize output
# LOOM_PRIVATE_MODE=1

# Port for the server
PORT=8000

# ── OAuth 2.1 configuration (for loom-server) ──────────────────────
# GitHub OAuth App credentials
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Secret key for signing JWTs (use a long random string)
JWT_SECRET=your-jwt-secret-change-me

# Base URL for OAuth redirect callbacks
LOOM_BASE_URL=http://localhost:8000

# Database URL for the SQLite backend (optional; defaults to JSON file)
# DATABASE_URL=sqlite:///path/to/loom.db
